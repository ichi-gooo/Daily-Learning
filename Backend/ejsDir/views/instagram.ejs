<%-include("includes/head.ejs")%>


<body>
    <h1>Hi its <%= data.name %> </h1>
    <button>follow</button>
    <button>message</button>
    <p>followers: <%= data.followers %> &nbsp; &nbsp; &nbsp;
    following: <%= data.following %></p>
    <hr>

    <h2>Posts</h2>
    <% for (let post of data.posts){ %>
        <img src="<%= post.image %>" alt = some image>
        <p>likes: <%= post.likes %> &nbsp; &nbsp; &nbsp;
    comments: <%= post.comments %></p>
    <% } %>


</body>

</html>